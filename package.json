{
  "name": "tingwu-zhongkao-ai-listening-speaking",
  "version": "1.0.0",
  "private": true,
  "description": "Tingwu Zhongkao AI Listening-Speaking Training System",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tingwu/zhongkao-ai-listening-speaking"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present -- --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run build --workspaces --if-present -- --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "openapi:validate": "redocly lint openapi/openapi.yaml",
    "openapi:generate:client": "openapi-generator-cli generate -i openapi/openapi.yaml -g typescript-fetch -o generated/sdk",
    "openapi:generate:server": "openapi-generator-cli generate -i openapi/openapi.yaml -g typescript-express-node -o generated/server-stub",
    "openapi:generate": "npm run openapi:generate:client && npm run openapi:generate:server",
    "contract:test": "dredd openapi/openapi.yaml http://127.0.0.1:3001 --only '/health > GET > 200 > application/json'",
    "setup": "npm install && docker-compose -f docker-compose.dev.yml up -d",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist dist"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.23.1",
    "@redocly/cli": "^1.34.5",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^6.13.0",
    "dotenv": "^17.3.1",
    "dredd": "^14.1.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
