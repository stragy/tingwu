# ============================================================
# 听悟中考AI听说训练系统 — 环境变量模板
# 复制本文件为 .env 并填入真实值，.env 已被 .gitignore 忽略
# ============================================================

# ── 必须设置（缺失则服务拒绝启动） ──────────────────────────

# JWT 签名密钥（至少 64 字符随机字符串）
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Refresh Token 签名密钥（与 JWT_SECRET 不同的随机字符串）
REFRESH_TOKEN_SECRET=

# 数据库密码
DB_PASSWORD=

# ── 数据库连接（可选，有安全默认值） ────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=tingwu
DB_NAME=tingwu_db

# 完整连接 URL（与上面单独字段二选一）
DATABASE_URL=postgresql://tingwu:${DB_PASSWORD}@localhost:5432/tingwu_db

# ── Redis ───────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# ── AWS S3（生产环境请使用真实 IAM 凭证或 IAM Role）────────
# 开发环境使用 LocalStack，保持 test/test 即可
# 生产环境：替换为真实 AWS 凭证，或使用 IAM Role（不写入此文件）
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=tingwu-audio-recordings

# ── AI 评估服务（接入真实 ASR/TTS 后填写）─────────────────
# 腾讯云 ASR（语音识别）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_APP_ID=
TENCENT_ASR_REGION=ap-guangzhou

# 科大讯飞（备用，可选）
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

# AI 评估模式: mock（内置规则引擎）| tencent | xfyun
EVALUATION_AI_PROVIDER=mock

# ── 服务端口 ────────────────────────────────────────────────

AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
PRACTICE_SERVICE_PORT=3003
EVALUATION_SERVICE_PORT=3004
SCHEDULING_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
GATEWAY_PORT=80

# ── 运行环境 ────────────────────────────────────────────────

NODE_ENV=development

# JWT 过期时间
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
